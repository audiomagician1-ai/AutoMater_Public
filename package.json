{
  "name": "automater",
  "version": "13.0.0",
  "private": true,
  "description": "智械母机 AutoMater — AI Agent 集群式软件开发桌面应用",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build:vite": "vite build",
    "build:prepare": "node scripts/prepare-build.js",
    "build": "vite build && node scripts/prepare-build.js && electron-builder",
    "release": "node scripts/release-build.js",
    "release:zip": "node scripts/release-build.js --no-installer",
    "electron:dev": "vite",
    "preview": "vite preview",
    "lint": "eslint src/ electron/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ electron/ --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"electron/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "quality-gate": "node scripts/quality-gate.js",
    "quality-gate:quick": "node scripts/quality-gate.js --quick"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "Tim",
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "clsx": "^2.1.0",
    "dagre": "^0.8.5",
    "lucide-react": "^0.468.0",
    "playwright-core": "^1.58.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "tailwind-merge": "^2.6.0",
    "ws": "^8.19.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron/asar": "^4.0.1",
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.0",
    "@types/dagre": "^0.7.54",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.0",
    "electron": "^33.3.0",
    "electron-builder": "^25.1.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "postcss": "^8.4.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "vitest": "^4.0.18"
  },
  "build": {
    "appId": "com.automater.app",
    "productName": "智械母机 AutoMater",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*",
      "!node_modules/.pnpm",
      "!node_modules/*/{test,tests,__tests__}/**",
      "!node_modules/*/{.git,.github}/**",
      "!node_modules/*/CHANGELOG*",
      "!node_modules/*/*.md"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "target": "dir"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
