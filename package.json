{
  "name": "agentforge",
  "version": "0.1.0",
  "private": true,
  "description": "AgentForge — AI Agent 集群式软件开发桌面应用",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build:vite": "vite build",
    "build:prepare": "node scripts/prepare-build.js",
    "build": "vite build && node scripts/prepare-build.js && electron-builder",
    "electron:dev": "vite",
    "preview": "vite preview"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "Tim",
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  },
  "dependencies": {
    "@types/dagre": "^0.7.54",
    "better-sqlite3": "^11.7.0",
    "clsx": "^2.1.0",
    "dagre": "^0.8.5",
    "lucide-react": "^0.468.0",
    "playwright-core": "^1.58.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^33.3.0",
    "electron-builder": "^25.1.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0"
  },
  "build": {
    "appId": "com.agentforge.app",
    "productName": "AgentForge",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*",
      "!node_modules/.pnpm",
      "!node_modules/*/{test,tests,__tests__}/**",
      "!node_modules/*/{.git,.github}/**",
      "!node_modules/*/CHANGELOG*",
      "!node_modules/*/*.md"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "target": "dir"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
